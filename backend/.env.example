APP_NAME=E-Office
APP_ENV=local
APP_PORT=8000
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000,http://127.0.0.1:3000

DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=eoffice_db
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_SSL=false

JWT_SECRET=change_this_secret
MAX_UPLOAD_SIZE=10485760
STORAGE_DRIVER=local
TIMEZONE=Asia/Jakarta

# Email integration for incoming/outgoing letters.
# Fill these with the official mailbox credentials or app-password.
EMAIL_SYNC_ENABLED=false
EMAIL_PROTOCOL=imap
EMAIL_ADDRESS=sekretariat@sttpu.ac.id
EMAIL_FROM_NAME=Sekretariat STTPU
EMAIL_HOST=mail.sttpu.ac.id
EMAIL_PORT=993
EMAIL_USER=sekretariat@sttpu.ac.id
EMAIL_USERNAME=sekretariat@sttpu.ac.id
EMAIL_PASSWORD=
EMAIL_IMAP_HOST=mail.sttpu.ac.id
EMAIL_IMAP_PORT=993
EMAIL_IMAP_SECURE=true
EMAIL_IMAP_MAILBOX=INBOX
EMAIL_SMTP_HOST=mail.sttpu.ac.id
EMAIL_SMTP_PORT=465
EMAIL_SMTP_SECURE=true
EMAIL_SYNC_LIMIT=25
EMAIL_SYNC_SINCE_DAYS=14
